[mysqld]

# Defaults noted here are from MariaDB 10.7 (official docker image)

#################################################
## Charset (default is utfmb4)

skip-character-set-client-handshake

#################################################
## Buffers

# default is 128M
innodb_buffer_pool_size = 256M

# default is 16M
tmp_table_size = 64M

# default is 16M
max_heap_table_size = 64M

# default is 256k
join_buffer_size = 4M

#################################################
## Misc

# default is 1
innodb_flush_log_at_trx_commit = 2

# default is 1
innodb_file_per_table = 1

#################################################
## Query log

# default is OFF
slow_query_log = 1

# default is a random filename
slow_query_log_file = /dev/stderr

# default is 10
long_query_time = 1

#################################################
## Connections

# default is 100
max_connections = 20

#################################################
## TYPO3 compatibility

# default is STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION
sql_mode = "NO_ENGINE_SUBSTITUTION"
